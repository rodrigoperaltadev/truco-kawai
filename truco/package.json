{
  "name": "truco-lab",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "web:export": "npx expo export --platform web",
    "lint": "npx biome check src __tests__ app.json biome.json jest.config.js tsconfig.json vercel.json",
    "format": "npx biome format --write src __tests__ app.json biome.json jest.config.js tsconfig.json vercel.json",
    "typecheck": "npx tsc --noEmit",
    "test": "npx jest"
  },
  "dependencies": {
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo-google-fonts/libre-caslon-text": "^0.4.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.5",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "getenv": "^2.0.0",
    "i18n-js": "^4.5.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@biomejs/biome": "^1.9.4",
    "@react-native/jest-preset": "^0.85.3",
    "@react-native/metro-config": "^0.85.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "packageManager": "yarn@1.22.22"
}
